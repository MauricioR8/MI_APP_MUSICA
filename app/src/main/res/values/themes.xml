<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. Compose drives the real theming at runtime;
         this XML theme only styles the window before the first frame. -->
    <style name="Theme.MiAppMusica" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme (androidx.core:core-splashscreen) -->
    <style name="Theme.MiAppMusica.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MiAppMusica</item>
    </style>
</resources>
